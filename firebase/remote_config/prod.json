{
  "parameters": {
    "translation_enabled": {
      "defaultValue": {
        "value": "true"
      },
      "valueType": "BOOLEAN",
      "description": "翻訳機能のON/OFF制御"
    },
    "translation_backend": {
      "defaultValue": {
        "value": "remote"
      },
      "valueType": "STRING",
      "description": "翻訳バックエンド: remote=Callable+Functions, local=翻訳スキップ"
    },
    "free_summary_limit": {
      "defaultValue": {
        "value": "3"
      },
      "valueType": "NUMBER",
      "description": "無料プランの1日要約上限"
    },
    "ads_enabled": {
      "defaultValue": {
        "value": "true"
      },
      "valueType": "BOOLEAN",
      "description": "広告表示のON/OFF（prodはtrue）"
    },
    "maintenance_mode": {
      "defaultValue": {
        "value": "false"
      },
      "valueType": "BOOLEAN",
      "description": "メンテナンス画面の表示制御"
    },
    "native_ad_interval": {
      "defaultValue": {
        "value": "10"
      },
      "valueType": "NUMBER",
      "description": "ネイティブ広告の差し込み間隔"
    }
  },
  "version": {
    "description": "initial config"
  }
}
